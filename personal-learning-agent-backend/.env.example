# LLM
GROQ_API_KEY="<your-api-key>"
GROQ_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.2

# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=*

# Persistence
# STATE_STORE=sqlite  (default, local file) or mongodb (shared, multi-user)
STATE_STORE=sqlite
DATABASE_URL=sqlite+aiosqlite:///./data/learner.db
CHROMA_PERSIST_DIR=./data/chroma

# MongoDB (when STATE_STORE=mongodb) – one document per user_id in collection ai-agent-backend
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/personal-learning-agent
# MONGODB_DATABASE=personal-learning-agent
# MONGODB_COLLECTION=ai-agent-backend

USE_MOCK_LLM=true

# External tools (optional)
ROADMAP_SERVICE_URL=http://localhost:8090
ROADMAP_REPO_PATH=./data/developer-roadmap
TAVILY_API_KEY="<tavily-api-key>"
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CALENDAR_CREDENTIALS_PATH=

# Quiz / plan defaults
DEFAULT_QUIZ_PASS_SCORE=70
INACTIVITY_NUDGE_DAYS=3
