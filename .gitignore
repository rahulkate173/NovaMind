# Root Gitignore for NovaMind Monorepo

# Dependencies
node_modules/
.venv/
venv/
env/
__pycache__/
*.py[cod]

# Environment variables & secrets
.env
.env.local
.env.*.local
*.env

# Build outputs & caches
dist/
build/
*.db
*.sqlite
*.sqlite3
data/
.chroma/
.pytest_cache/
.mypy_cache/
coverage/

# OS / Editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
